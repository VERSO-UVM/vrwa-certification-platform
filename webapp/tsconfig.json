{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "rootDirs": [".", "./.react-router/types"],

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/",

    "paths": {
      "~/*": ["./app/*"],
      "@backend/*": ["../backend/src/*"]
    }
  },
  "references": [{ "path": "../backend" }],
  "include": ["app", ".react-router/types"]
}
